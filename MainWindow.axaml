<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Academy.MainWindow"
        Title="Academy SPU_411"
        Background="Black">
    <DockPanel LastChildFill="True">
        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="#333333" Padding="5,2">
            <TextBlock x:Name="statusText" Text="Ready" Foreground="White" />
        </Border>
        
        <!-- TabControl -->
        <TabControl x:Name="tabControl" 
                    SelectionChanged="TabControl_SelectedIndexChanged"
                    Background="Black">
            <TabItem Header="Students" />
            <TabItem Header="Groups" />
            <TabItem Header="Directions">
                <DataGrid x:Name="dgvDirections"
                          AutoGenerateColumns="True"
                          CanUserResizeColumns="True"
                          Background="Black"
                          Foreground="White" />
            </TabItem>
            <TabItem Header="Disciplines" />
            <TabItem Header="Teachers" />
        </TabControl>
    </DockPanel>
</Window>
